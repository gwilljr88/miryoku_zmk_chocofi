/* * 1. Enable the SPI hardware on the board 
 */
&spi0 {
    status = "okay";
};

/* * 2. Create an alias/label in the root for the shield to find 
 */
/ {
    nice_view_spi: &spi0 { };

    chosen {
        zmk,studio-rpc-endpoint = &studio_rpc_usb;
    };

    studio_rpc_usb: studio_rpc_usb {
        compatible = "zmk,studio-rpc-usb-uart";
        label = "STUDIO_RPC_USB";
    };
};
