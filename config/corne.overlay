/* Enable USB and UART for ZMK Studio RPC */
/ {
    nice_view_spi: &spi0 {
        status = "okay";
    };
    
    chosen {
        zmk,studio-rpc-endpoint = &studio_rpc_usb;
    };

    studio_rpc_usb: studio_rpc_usb {
        compatible = "zmk,studio-rpc-uart";
        status = "okay";
        label = "STUDIO_RPC_USB";
    };
};
